{
  "manifest_version": 3,
  "name": "Stashy",
  "version": "1.3.0",
  "description": "Compares Steam and Epic Games libraries, displaying ownership badges directly on store pages.",
  "author": "blosny",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://steamcommunity.com/*",
    "https://store.epicgames.com/*",
    "https://www.epicgames.com/*",
    "https://epicgames.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/profiles/*/games*",
        "https://steamcommunity.com/id/*/games*"
      ],
      "js": ["content/steam-library.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.epicgames.com/account*",
        "https://epicgames.com/account*",
        "https://accounts.epicgames.com/*",
        "https://epicgames.com/id/*",
        "https://www.epicgames.com/id/*"
      ],
      "js": ["content/epic-library.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://store.steampowered.com/app/*",
        "https://store.epicgames.com/*/p/*",
        "https://store.epicgames.com/*/store/*",
        "https://store.epicgames.com/p/*",
        "https://store.epicgames.com/store/*"
      ],
      "js": ["content/badge.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Stashy"
  },

  "icons": {
    "16": "icons/icon-48.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "stashy@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
